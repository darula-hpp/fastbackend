{
  "name": "@fastbackend/core",
  "version": "0.1.1",
  "description": "Core schema parsing and IR generation for FastBackend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darula-hpp/uigen.git",
    "directory": "fastbackend/packages/core"
  },
  "homepage": "https://github.com/darula-hpp/uigen/tree/main/fastbackend/packages/core",
  "bugs": {
    "url": "https://github.com/darula-hpp/uigen/issues"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.py",
    "dist/**/*.json",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp src/parsers/sqlalchemy/parser.py dist/parsers/sqlalchemy/ && cp src/ir/schema.json dist/ir/",
    "prepublishOnly": "pnpm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "fastbackend",
    "schema-parser",
    "ir-generator",
    "openapi",
    "backend-framework"
  ],
  "publishConfig": {
    "access": "public"
  }
}
